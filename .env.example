# ---- Database ----
DATABASE_URL=postgres://medusa:medusa@localhost:5433/medusa-kami
REDIS_URL=redis://localhost:6380

# ---- Medusa HTTP ----
TZ=Asia/Ho_Chi_Minh
JWT_SECRET=change_me_jwt
COOKIE_SECRET=change_me_cookie
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:7001
AUTH_CORS=http://localhost:7001

# ---- DeepSeek (KAMI model provider) ----
DEEPSEEK_API_KEY=replace_with_deepseek_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
KAMI_MODEL=deepseek-v4-pro
KAMI_TIMEZONE=Asia/Ho_Chi_Minh
KAMI_UTC_OFFSET=UTC+7
KAMI_REASONING_EFFORT=high
# "true" => gửi extra_body { thinking: { type: "enabled" } }
KAMI_THINKING=true

# ---- KAMI runtime guards (Phase 1) ----
KAMI_TEST_MOCK_LLM=false
KAMI_MAX_ITERATIONS=25
KAMI_MAX_TOKENS_PER_TURN=60000
KAMI_CONTEXT_LIMIT=128000
KAMI_APPROVAL_REQUIRED=true
KAMI_DESTRUCTIVE_TOOLS=delete_product,cancel_order,refund_order
KAMI_HALT=false

# ---- KAMI runtime recovery (Phase 2) ----
KAMI_FALLBACK_MODEL=deepseek-chat
KAMI_HEALTHCHECK_ENABLED=true
KAMI_MAX_RETRIES=3
KAMI_RETRY_DELAY_MS=1000

# ---- KAMI voice / ASR (OpenAI Realtime + Transcription) ----
# Keep the real key only in .env. The admin UI never receives this secret.
OPENAI_API_KEY=replace_with_openai_key
KAMI_VOICE_MODEL=gpt-realtime-2
KAMI_TRANSCRIBE_MODEL=gpt-4o-transcribe
KAMI_REALTIME_TRANSCRIBE_MODEL=gpt-realtime-whisper
KAMI_REALTIME_TRANSCRIBE_DELAY=low
KAMI_VOICE_SAMPLE_RATE=24000
KAMI_VOICE_WS_PORT=9901
KAMI_PUBLIC_HOST=localhost
KAMI_REALTIME_WS_SCHEME=ws
KAMI_REALTIME_WS_BIND_HOST=127.0.0.1

# ---- KAMI gateways (Phase 4) ----
# Telegram: create bot with @BotFather → copy token. Optional secret for webhook auth.
# KAMI_GATEWAY_TELEGRAM_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# KAMI_GATEWAY_TELEGRAM_SECRET=my-webhook-secret
# Discord: create app at https://discord.com/developers/applications → Bot token + Public Key.
# KAMI_GATEWAY_DISCORD_TOKEN=...
# KAMI_GATEWAY_DISCORD_PUBLIC_KEY=...
# Slack: create app at https://api.slack.com/apps → Bot Token + Signing Secret.
# KAMI_GATEWAY_SLACK_TOKEN=xoxb-...
# KAMI_GATEWAY_SLACK_SIGNING_SECRET=...

# ---- KAMI sandbox — code_exec tool (Phase 5) ----
# Enable Docker-based code execution. Requires Docker daemon running.
# KAMI_SANDBOX_ENABLED=true
# KAMI_SANDBOX_IMAGE=alpine:3.20
# KAMI_SANDBOX_TIMEOUT_MS=30000
# KAMI_SANDBOX_MEMORY_MB=128
# KAMI_SANDBOX_NETWORK=false
# KAMI_SANDBOX_READONLY=true

# ---- KAMI memory providers (Phase 6) ----
# Embedding-based memory uses the same DeepSeek API key.
# The embedding client falls back to a hash-based vector when the API is unavailable.
# Dialectic memory detects contradictions and consolidates beliefs through LLM review.
