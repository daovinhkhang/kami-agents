{
  "compilerOptions": {
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "module": "Node16",
    "target": "ES2021",
    "moduleResolution": "Node16",
    "jsx": "react-jsx",
    "isolatedModules": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noUnusedParameters": false,
    "strict": false,
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "allowJs": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@models": ["./src/modules/kami/models/index"],
      "@models/*": ["./src/modules/kami/models/*"],
      "@services": ["./src/modules/kami/services/index"],
      "@services/*": ["./src/modules/kami/services/*"],
      "@types": ["./src/modules/kami/types/index"],
      "@repositories": ["./src/modules/kami/repositories/index"],
      "@kami/*": ["./src/kami-runtime/*"]
    }
  },
  "include": ["src", "medusa-config.ts"],
  "exclude": ["node_modules", "dist"]
}
